static void populateCapteurList(QListWidget *list, const QList<QPair<int, QString>> &features, const QStringList &selected)
{
    if (!list) return;
    list->clear();
    list->setSelectionMode(QAbstractItemView::MultiSelection);

    if (features.isEmpty()) {
        QListWidgetItem *emptyItem = new QListWidgetItem("Aucun capteur en stock", list);
        emptyItem->setFlags(Qt::NoItemFlags);
        return;
    }

    for (const auto &entry : features) {
        const int idMp = entry.first;
        const QString name = entry.second.trimmed();
        if (name.isEmpty()) continue;
        QListWidgetItem *item = new QListWidgetItem(name, list);
        item->setFlags(item->flags() | Qt::ItemIsUserCheckable | Qt::ItemIsSelectable | Qt::ItemIsEnabled);
        const bool isSelected = listContainsInsensitive(selected, name);
        item->setCheckState(isSelected ? Qt::Checked : Qt::Unchecked);
        item->setSelected(isSelected);
        item->setData(Qt::UserRole, idMp);
    }
}

static int selectedCapteurQtyLimit(QListWidget *list, QString *errorText = nullptr)
{
    if (errorText) errorText->clear();
    if (!list) return -1;

    const QStringList reservedFeatures = list->property("prodCurrentFeatures").toStringList();
    const int reservedQty = list->property("prodCurrentQty").toInt();

    bool hasSelection = false;
    int limit = -1;

    QSqlQuery query;
    query.prepare("SELECT NVL(QUANTITE, 0) FROM MATIERE_PREMIERE WHERE ID_MP = :id_mp");

    for (int i = 0; i < list->count(); ++i) {
        QListWidgetItem *item = list->item(i);
        if (!item) continue;
        if (!(item->checkState() == Qt::Checked || item->isSelected())) continue;

        const int idMp = item->data(Qt::UserRole).toInt();
        if (idMp <= 0) continue;

        hasSelection = true;
        query.bindValue(":id_mp", idMp);
        if (!query.exec() || !query.next()) {
            if (errorText) *errorText = query.lastError().text();
            return -1;
        }

        int availableQty = query.value(0).toInt();
        if (reservedQty > 0 && listContainsInsensitive(reservedFeatures, item->text())) {
            availableQty += reservedQty;
        }

        if (limit < 0 || availableQty < limit) {
            limit = availableQty;
        }
    }

    return hasSelection ? qMax(0, limit) : -1;
}

static void applyProduitQuantityLimitFromSelection(QListWidget *list, QSpinBox *spin)
{
    if (!list || !spin) return;

    if (!spin->property("prodBaseMax").isValid()) {
        spin->setProperty("prodBaseMax", spin->maximum());
    }

    const int baseMax = qMax(spin->minimum(), spin->property("prodBaseMax").toInt());
    QString errorText;
    const int limit = selectedCapteurQtyLimit(list, &errorText);

    if (!errorText.trimmed().isEmpty()) {
        list->setToolTip("Impossible de calculer la quantite maximale selon le stock des capteurs.");
        spin->setToolTip("Impossible de calculer la quantite maximale selon le stock des capteurs.");
        spin->setMaximum(baseMax);
        return;
    }

    if (limit < 0) {
        spin->setMaximum(baseMax);
        const QString tip = "Selectionnez un ou plusieurs capteurs pour limiter automatiquement la quantite selon le stock disponible.";
        list->setToolTip(tip);
        spin->setToolTip(tip);
        return;
    }

    const int finalMax = qMax(spin->minimum(), limit);
    spin->setMaximum(finalMax);
    if (spin->value() > finalMax) {
        QSignalBlocker blocker(spin);
        spin->setValue(finalMax);
    }

    const QString tip = QString("Quantite maximale autorisee selon les capteurs selectionnes : %1.").arg(finalMax);
    list->setToolTip(tip);
    spin->setToolTip(tip);
}

