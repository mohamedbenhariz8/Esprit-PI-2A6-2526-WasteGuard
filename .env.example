# ============================================================
# WasteGuard — modèle de variables d'environnement
# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# NE JAMAIS committer le fichier .env réel.
# ============================================================

# --- Base de données Oracle (ODBC) ---
WASTEGUARD_DB_NAME=Source_Projet2A
WASTEGUARD_DB_USER=wasteguard
WASTEGUARD_DB_PASSWORD=change_me

# --- IoT / Tracking ---
# URL publique ngrok du serveur de tracking (générée au lancement)
TRACKING_URL_FILE=ngrok_url.txt
# Port série de la carte ESP32 (ex: COM5 sous Windows, /dev/ttyUSB0 sous Linux)
ESP32_SERIAL_PORT=COM5

# --- IA / Vision (classification des déchets) ---
# Lien de téléchargement du modèle YOLO entraîné (Hugging Face / Drive / Kaggle)
WASTE_MODEL_URL=https://huggingface.co/kendrickfff/waste-classification-yolov8-ken
# Chemin local du modèle après téléchargement
WASTE_MODEL_PATH=models/waste_yolo.pt

# --- Chatbot / Assistant Labib ---
# Clé API du fournisseur LLM si utilisé (laisser vide pour Ollama local)
LLM_API_KEY=
# Hugging Face Inference API (chat / vision) — voir floatingaiwidget.cpp
HF_API_KEY=

# --- Notifications email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
