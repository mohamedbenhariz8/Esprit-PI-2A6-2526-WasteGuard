# ===========================================================
# WasteGuard — .gitignore
# ===========================================================

# ---- Build artifacts ----
debug/
release/
*.o
*.obj
*.a
*.lib
*.dll
*.exe
Makefile*
.qmake.stash
ui_mainwindow.h
test_ui_mainwindow.h
mocinclude.opt

# ---- Qt Creator / IDE specific ----
*.pro.user
*.pro.user.*
.qtcreator/
.vscode/
.idea/
.vs/
*.swp

# ---- Backups and Temporary files ----
*.bak
*.bak_*
*.backup
*.backup_*
mainwindow.ui.backup*
mainwindow_temp.ui
*.log
nul)
diff.txt

# ---- Secrets — never commit the real .env ----
.env
ngrok_url.txt

# ---- Python artifacts ----
.venv/
__pycache__/
*.pyc
*.pyo

# ---- Trained models / large media (host externally, link in README) ----
*.pt
*.pth
*.onnx
*.h5
*.keras
*.pkl
*.joblib
ngrok.exe

