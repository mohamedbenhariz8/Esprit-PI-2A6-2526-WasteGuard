<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1505</width>
    <height>1030</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>WasteGuard - Gestion des Employes</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow, QWidget {
    background-color: #f4f6f9; 
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

QLabel {
    color: #333333 !important;
    font-weight: 600;
}

QFrame#sidebar {
    background-color: #0f2b4c;
    border: none;
}
QFrame#sidebar QLabel {
    color: white !important;
    background-color: transparent; 
}

QLabel#label_logo {
    background-color: transparent !important;
    border: none;
}

QFrame#sidebar QPushButton {
    background-color: transparent;
    border: none;
    color: #bdc3c7;
    text-align: left;
    padding: 12px 20px;
    font-size: 14px;
    border-left: 3px solid transparent;
}
QFrame#sidebar QPushButton:hover, QFrame#sidebar QPushButton:checked {
    background-color: #1a4270;
    color: white;
    border-left: 3px solid #3498db;
}

QFrame#statCard, QFrame#statCard_2, QFrame#statCard_3, QFrame#actionCard, QFrame#cardFrame, QFrame#cardFrame_2 { 
    background-color: #f4f6f9;
    border-radius: 12px;
    border: 1px solid #dce1e6;
    border-bottom: 2px solid #dce1e6;
}

QLabel#lblStatNumber {
    font-size: 24px;
    font-weight: bold;
    color: #0f2b4c !important;
}

QPushButton#btnExport, QPushButton#btnFichePaie {
    background-color: #ffffff;
    color: #333333 !important;
    border: 1px solid #cccccc;
    border-radius: 8px;
    padding: 10px 15px;
    text-align: left;
    font-weight: bold;
    font-size: 13px;
    margin-top: 5px;
}
QPushButton#btnExport:hover, QPushButton#btnFichePaie:hover {
    background-color: #e3f2fd;
    border: 1px solid #3498db;
    color: #0f2b4c !important;
}

QPushButton#btnSave, QPushButton#btnAjouter, QPushButton#btnNouveau {
    background-color: #28a745;
    color: white !important;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
    border: none;
}
QPushButton#btnSave:hover, QPushButton#btnAjouter:hover, QPushButton#btnNouveau:hover {
    background-color: #218838;
}
QPushButton#btnNouveau {
    background-color: #0f2b4c;
}
QPushButton#btnNouveau:hover {
    background-color: #1a4270;
}

QPushButton#btnAnnuler, QPushButton#btnAnnuler_Ajout {
    background-color: #6c757d;
    color: white !important;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
    border: none;
}
QPushButton#btnAnnuler:hover, QPushButton#btnAnnuler_Ajout:hover {
    background-color: #5a6268;
}

QPushButton#btnDelete {
    background-color: #dc3545;
    color: white !important;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
    border: none;
}
QPushButton#btnDelete:hover {
    background-color: #c82333;
}

QPushButton#btnUploadPhoto, QPushButton#btnUploadPhoto_Ajout {
    background-color: #ffffff;
    color: #0f2b4c !important;
    border: 1px dashed #0f2b4c;
    border-radius: 8px;
    padding: 6px;
    font-weight: bold;
    margin-top: 5px;
}
QPushButton#btnUploadPhoto:hover, QPushButton#btnUploadPhoto_Ajout:hover {
    background-color: #e3f2fd;
    border: 1px solid #0f2b4c;
}

QTableWidget {
    background-color: #f4f6f9;
    alternate-background-color: #e8ebf0;
    color: #000000 !important;
    gridline-color: transparent;
    border: 1px solid #dce1e6;
    border-radius: 8px;
    font-size: 13px;
}
QTableWidget::item {
    color: #000000 !important;
    padding: 5px;
    border-bottom: 1px solid #e0e6ed;
}
QTableWidget::item:selected {
    background-color: #e3f2fd;
    color: #0f2b4c !important;
}
QHeaderView::section {
    background-color: #0f2b4c;
    color: white;
    padding: 8px;
    border: none;
    font-weight: bold;
    font-size: 13px;
}

QLineEdit {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 6px;
}
QLineEdit:focus {
    border: 1px solid #3498db;
}

QComboBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 6px;
}
QComboBox:focus {
    border: 1px solid #3498db;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    selection-background-color: #0f2b4c;
    selection-color: #ffffff;
    border: 1px solid #cccccc;
}

QLabel#imageLabel, QLabel#imageLabel_2 {
    border: 1px solid #cccccc;
    border-radius: 10px;
    background-color: #f4f6f9;
    color: #888888 !important;
}

QTabWidget::pane { border: none; }
QTabBar::tab {
    background: #e0e4e8;
    color: #333 !important;
    padding: 8px 20px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background: #0f2b4c;
    color: white !important;
}

QLabel#lblUserName, QLabel#lblUserName_Modif, QLabel#lblUserName_Ajout {
    font-size: 14px;
    font-weight: bold;
    color: #0f2b4c !important;
}
QLabel#lblUserRole, QLabel#lblUserRole_Modif, QLabel#lblUserRole_Ajout {
    font-size: 12px;
    font-weight: bold;
    color: #28a745 !important;
    margin-top: -2px;
}

/* Style Sp?cifique pour l'onglet Mission */
QPushButton#btnAnalyser {
    background-color: #6c5ce7;
    color: white;
    font-weight: bold;
    padding: 12px;
    border-radius: 6px;
}
QPushButton#btnAnalyser:hover {
    background-color: #5b4cc4;
}
QLabel#lblTitreMission {
    font-size: 16px;
    color: #0f2b4c !important;
}
QLabel#lblResultat {
    font-size: 14px;
    color: #27ae60 !important;
}

/* Style pour l'onglet Pointage */
QLabel#lblStatutRFID {
    background-color: #ecf0f1;
    color: #7f8c8d;
    font-size: 24px;
    font-weight: bold;
    border-radius: 10px;
    padding: 20px;
    border: 2px dashed #bdc3c7;
}
QPushButton#btnSimulerBadge {
    background-color: #e67e22;
    color: white;
    font-weight: bold;
    padding: 10px;
    border-radius: 5px;
    margin-top: 10px;
}
QPushButton#btnSimulerBadge:hover {
    background-color: #d35400;
}

QSlider::groove:horizontal {
    border: 1px solid #cccccc;
    height: 8px;
    background: #e0e0e0;
    margin: 2px 0;
    border-radius: 4px;
}
QSlider::handle:horizontal {
    background: #0f2b4c;
    border: 1px solid #0f2b4c;
    width: 18px;
    height: 18px;
    margin: -6px 0;
    border-radius: 9px;
}
/* ======================================================= */
/* STYLE UNIFI? POUR LES 5 BOUTONS PRINCIPAUX              */
/* ======================================================= */

/* 1. Style de base pour les deux boutons du haut ET les trois du bas */
QPushButton#btnFichePaie, QPushButton#btnExport,
QPushButton#btnGoMission, QPushButton#btnGoPointage, QPushButton#btnGoStats {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #dcdcdc;
    border-radius: 8px;
    padding: 15px 20px;
    font-size: 14px;
    font-weight: bold;
    text-align: left;
}

/* 2. Effet quand la souris passe dessus (Hover) pour les 5 boutons */
QPushButton#btnFichePaie:hover, QPushButton#btnExport:hover,
QPushButton#btnGoMission:hover, QPushButton#btnGoPointage:hover, QPushButton#btnGoStats:hover {
    background-color: #f0f8ff;
    border: 1px solid #3498db;
    color: #000000 !important;
}

/* 3. Effet quand on clique dessus (Pressed) pour les 5 boutons */
QPushButton#btnFichePaie:pressed, QPushButton#btnExport:pressed,
QPushButton#btnGoMission:pressed, QPushButton#btnGoPointage:pressed, QPushButton#btnGoStats:pressed {
    background-color: #e1ecf4;
    border: 1px solid #2980b9;
}
/* Style pour les boutons de RETOUR dans les pages Mission, Pointage et Stats */
QPushButton#btnAnnulerMission, 
QPushButton#btnAnnulerPointage, 
QPushButton#btnAnnulerStats {
    background-color: #6c757d;  
    color: white;               
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    font-weight: bold;
    font-size: 14px;
    min-width: 200px;           
    margin-top: 20px;           
}

/* Effet au survol */
QPushButton#btnAnnulerMission:hover, 
QPushButton#btnAnnulerPointage:hover, 
QPushButton#btnAnnulerStats:hover {
    background-color: #5a6268;  
}
/* ======================================================= */
/* 1. CORRECTION DES BOUTONS DE RETOUR (Pages internes)    */
/* ======================================================= */
/* Cela rendra les boutons &quot;Retour&quot; bien visibles en gris fonc? */
QPushButton#btnAnnulerMission, 
QPushButton#btnAnnulerPointage, 
QPushButton#btnAnnulerStats {
    background-color: #6c757d;  
    color: white !important;    
    border: none;
    border-radius: 6px;
    padding: 10px 25px;         
    font-weight: bold;
    font-size: 14px;
    margin-top: 15px;           
    min-width: 150px;           
}

QPushButton#btnAnnulerMission:hover, 
QPushButton#btnAnnulerPointage:hover, 
QPushButton#btnAnnulerStats:hover {
    background-color: #5a6268;  
}

/* ======================================================= */
/* 2. CORRECTION DE LA BOITE DE DIALOGUE (Supprimer)       */
/* ======================================================= */
QPushButton#msgBoxYes, QPushButton#msgBoxNo {
    background-color: #0f2b4c;
    color: white !important;
    border-radius: 5px;
    padding: 6px 20px;
    min-width: 80px;
    font-weight: bold;
}
QMessageBox QPushButton {
    background-color: #0f2b4c;
    color: white !important;
    border-radius: 5px;
    padding: 6px 20px;
    min-width: 80px;
    font-weight: bold;
}

QMessageBox QPushButton:hover {
    background-color: #1a4270;
}

/* ======================================================= */
/* 3. UNIFICATION DES 5 BOUTONS DU DASHBOARD (Accueil)     */
/* ======================================================= */
QPushButton#btnFichePaie, QPushButton#btnExport,
QPushButton#btnGoMission, QPushButton#btnGoPointage, QPushButton#btnGoStats {
    background-color: #ffffff;
    color: #333333 !important;
    border: 1px solid #dcdcdc;
    border-radius: 8px;
    padding: 15px;
    font-size: 14px;
    font-weight: bold;
    text-align: center;
}

QPushButton#btnFichePaie:hover, QPushButton#btnExport:hover,
QPushButton#btnGoMission:hover, QPushButton#btnGoPointage:hover, QPushButton#btnGoStats:hover {
    background-color: #e3f2fd;
    border: 1px solid #3498db;
    color: #000000 !important;
}
/* STYLE MAINTENANCE (AJOUTE)                              */
/* ======================================================= */
QWidget#sideDashboard, QWidget#sideAjout, QWidget#sideMod {
    background-color: #0f2b4c;
    border: none;
}
QWidget#sideDashboard QLabel, QWidget#sideAjout QLabel, QWidget#sideMod QLabel {
    color: white;
    background-color: transparent; 
}
/* Boutons du menu lateral Maintenance */
QPushButton[objectName^=&quot;sideMenuButton&quot;] {
    background-color: transparent;
    border: none;
    color: #bdc3c7;
    text-align: left;
    padding: 12px 20px;
    font-size: 14px;
    border-left: 3px solid transparent;
}
QPushButton[objectName^=&quot;sideMenuButton&quot;]:hover, 
QPushButton[objectName^=&quot;sideMenuButton&quot;]:checked {
    background-color: #1a4270;
    color: white;
    border-left: 3px solid #3498db;
}
/* Bouton RETOUR special Sidebar */
QPushButton#btnBack_Ajout, QPushButton#btnBack_Modif {
    background-color: #d35400; 
    color: white;
    border: none;
    border-radius: 4px;
    padding: 8px 15px;
    font-weight: bold;
    text-align: center;
    margin: 10px 15px;
}
QPushButton#btnBack_Ajout:hover, QPushButton#btnBack_Modif:hover {
    background-color: #e67e22;
}
/* TOP BAR Maintenance */
QFrame#topBar, QFrame#topBar_Aj, QFrame#topBar_Mod {
    background-color: #ffffff;
    border-bottom: 1px solid #dce1e6;
}
QFrame#topBar QLabel, QFrame#topBar_Aj QLabel, QFrame#topBar_Mod QLabel {
    color: #0f2b4c;
}
/* CARTES ET CONTENEURS Maintenance */
QFrame#card, QFrame#cardAdd, QFrame#cardMod, 
QFrame#rightSidebar, QFrame#stat1, QFrame#stat2, QFrame#stat3 { 
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #dce1e6;
    border-bottom: 2px solid #dce1e6;
}
/* Stats Textes Maintenance */
QLabel.statValue, QLabel.alertValue {
    font-size: 24px;
    font-weight: bold;
    color: #0f2b4c;
}
QLabel.statLabel {
    color: #546e7a;
    font-size: 13px;
}
QLabel.alertValue {
    color: #c62828;
}
QFrame.alertCard {
    background-color: #ffebee;
    border: 1px solid #ffcdd2;
}
/* BOUTONS D'ACTION Maintenance */
QPushButton#btnSave_Add, QPushButton#btnSave_Mod, QPushButton#btnGotoModifier {
    background-color: #28a745;
    color: white;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
    border: none;
}
QPushButton#btnSave_Add:hover, QPushButton#btnSave_Mod:hover {
    background-color: #218838;
}
QPushButton#btnGotoAjout {
    background-color: #0f2b4c;
    color: #ffffff;
    border-radius: 10px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 700;
    border: none;
}
QPushButton#btnGotoAjout:hover {
    background-color: #1a4270;
}
QPushButton#btnCancel_Add, QPushButton#btnCancel_Mod {
    background-color: #6c757d;
    color: white;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
    border: none;
}
QPushButton#btnCancel_Add:hover, QPushButton#btnCancel_Mod:hover {
    background-color: #5a6268;
}
QPushButton#btnPdf {
    background-color: #ffffff;
    color: #1f2d3d;
    border: 1px solid #dce1e6;
    border-radius: 10px;
    padding: 12px 16px;
    text-align: center;
    font-weight: 700;
    font-size: 14px;
    min-height: 52px;
}
QPushButton#btnPdf:hover {
    background-color: #e3f2fd;
    border: 1px solid #3498db;
    color: #0f2b4c;
}
QPushButton#btnPdf:disabled {
    background-color: #ffffff;
    color: #1f2d3d;
    border: 1px solid #dce1e6;
}
QPushButton#btnNotif, QPushButton#btnProfil {
    background-color: #f0f2f5;
    border-radius: 4px;
    padding: 6px;
    border: 1px solid #dce1e6;
    color: #0f2b4c;
}
QPushButton#btnNotif:hover, QPushButton#btnProfil:hover {
    background-color: #e3f2fd;
    border-color: #3498db;
}
/* FORMULAIRES Maintenance */
QLineEdit, QSpinBox, QDoubleSpinBox, QDateEdit {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 6px;
    min-height: 20px;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QDateEdit:focus {
    border: 1px solid #3498db;
}
QComboBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 6px;
}
QComboBox:focus {
    border: 1px solid #3498db;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    selection-background-color: #0f2b4c;
    selection-color: #ffffff;
    border: 1px solid #cccccc;
}
QTextEdit {
    background-color: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 8px;
    padding: 6px;
    color: #333333;
}
QLabel.formLabel {
    color: #0f2b4c;
    font-weight: 700;
    font-size: 13px;
    margin-bottom: 4px;
}
QLabel#lblImgPreview_Add, QLabel#lblImgPreview_Mod, QLabel#lblImgPreview2_Add {
    border: 2px dashed #0f2b4c;
    border-radius: 10px;
    background-color: #f4f6f9;
    color: #888888;
}

 QPushButton#btnAddDashboard,
QPushButton#btnAddProduct_2,
QPushButton#btnSave_Mod,
QPushButton#btnSave_Mod_3 {
    background-color: #49b14f;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 700;
}

QPushButton#btnAddDashboard:hover,
QPushButton#btnAddProduct_2:hover,
QPushButton#btnSave_Mod:hover,
QPushButton#btnSave_Mod_3:hover {
    background-color: #3ea445;
}

QPushButton#btnTempToModifier {
    background-color: #124e84;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 700;
}

QPushButton#btnTempToModifier:hover {
    background-color: #0f3f6a;
}

QPushButton#btnCancel_Mod,
QPushButton#btnCancel_Mod_3 {
    background-color: #a9b8c3;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 700;
}

QPushButton#btnCancel_Mod:hover,
QPushButton#btnCancel_Mod_3:hover {
    background-color: #96a7b4;
}

QFrame#topFill_1, QFrame#topFill_3, QFrame#topFill_5,
QFrame#topGap_1, QFrame#topGap_3, QFrame#topGap_5 {
    background-color: #0f2f57;
    border: none;
    min-height: 56px;
    max-height: 56px;
    border-radius: 0px;
}

QLabel#lb_1, QLabel#lb_3, QLabel#lb_5 {
    background-color: #0f2f57;
    color: #ffffff;
    font-size: 18px;
    font-weight: 800;
    padding: 0px 20px;
    min-height: 56px;
    max-height: 56px;
    border-radius: 0px;
}

QLabel#user_1, QLabel#user_3, QLabel#user_5 {
    background-color: #0f2f57;
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    padding: 0px 10px 0px 0px;
    min-height: 56px;
    max-height: 56px;
    border-radius: 0px;
}

QPushButton#btnnotif_3, QPushButton#btnnotif_5 {
    background-color: #0f2f57;
    color: #f0b331;
    border: none;
    border-radius: 0px;
    min-width: 40px;
    max-width: 40px;
    min-height: 56px;
    max-height: 56px;
    padding: 0px;
}

QPushButton#btnprofil_3, QPushButton#btnprofil_5 {
    background-color: #0f2f57;
    color: #6b4b8a;
    border: none;
    border-radius: 0px;
    min-width: 40px;
    max-width: 40px;
    min-height: 56px;
    max-height: 56px;
    padding: 0px;
}

/* --- Unified right sidebars (Employees reference) --- */
QFrame#sidePanel_Employe,
QFrame#rightSidebar,
QFrame#rightSidebar_Commande,
QWidget#sidepanel,
QFrame#prod_rightSidebar {
    background: transparent;
    border: none;
}

QFrame#statCard, QFrame#statCard_2, QFrame#statCard_3, QFrame#actionCard,
QFrame#statsBox, QFrame#orderBox,
QWidget#growthWidget {
    background-color: #ffffff;
    border: 1px solid #dce1e6;
    border-radius: 12px;
}

QFrame#stat1, QFrame#stat2, QFrame#stat3,
QFrame#stat1_Cmd, QFrame#stat2_Cmd, QFrame#stat3_Cmd {
    background-color: #ffffff;
    border: none;
    border-radius: 16px;
    padding: 18px 16px;
}

QFrame#stat1:hover, QFrame#stat2:hover, QFrame#stat3:hover,
QFrame#stat1_Cmd:hover, QFrame#stat2_Cmd:hover, QFrame#stat3_Cmd:hover {
    background-color: #f0f7ff;
    border: 1px solid #b3d4fc;
}

QLabel#lblFunc, QLabel#lblFunc_Cmd, QLabel#pilotage, QLabel#lblStatsTitle, QLabel#lblOrderTitle, QLabel#label_Actions {
    color: #1f2d3d;
    font-size: 15px;
    font-weight: 700;
}

QLabel#st_icon1, QLabel#st_icon2, QLabel#st_icon3,
QLabel#st_icon1_Cmd, QLabel#st_icon2_Cmd, QLabel#st_icon3_Cmd {
    font-size: 28px;
    padding: 0px;
    background: transparent;
    border: none;
}

QFrame#miniChartFrame {
    background-color: #ffffff;
    border: none;
    border-radius: 16px;
    padding: 14px;
}

QLabel#lblMiniChartTitle {
    font-size: 13px;
    font-weight: 700;
    color: #1f2d3d;
}

QLabel#lblMiniBar1, QLabel#lblMiniBar2, QLabel#lblMiniBar3 {
    font-size: 12px;
    color: #4a5568;
    font-weight: 500;
}

QProgressBar#pbMini1, QProgressBar#pbMini2, QProgressBar#pbMini3 {
    border: none;
    border-radius: 5px;
    background-color: #e2e8f0;
    min-height: 10px;
    max-height: 10px;
    text-align: center;
}

QProgressBar#pbMini1::chunk {
    background-color: #38a169;
    border-radius: 5px;
}

QProgressBar#pbMini2::chunk {
    background-color: #3182ce;
    border-radius: 5px;
}

QProgressBar#pbMini3::chunk {
    background-color: #e53e3e;
    border-radius: 5px;
}

QLabel#lblMiniPct1, QLabel#lblMiniPct2, QLabel#lblMiniPct3 {
    font-size: 11px;
    font-weight: 700;
    color: #2d3748;
    min-width: 32px;
}

QPushButton#btnFichePaie, QPushButton#btnGoMission, QPushButton#btnGoPointage, QPushButton#btnGoStats, QPushButton#btnExport,
