       <property name="styleSheet">
        <string>#popupFrame { background-color: #eff3f8; border-radius: 24px; }

#btnOpenStats {
    background-color: #2f6fa8;
    color: white;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight: 600;
}
#btnOpenStats:hover { background-color: #295f90; }
#btnOpenStats:pressed { background-color: #234f77; }

#btnCancel_Add, #btnCancel_Mod {
    background-color: #b9c3cc;
    color: white;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight: 600;
}
#btnCancel_Add:hover, #btnCancel_Mod:hover { background-color: #aab5bf; }
#btnCancel_Add:pressed, #btnCancel_Mod:pressed { background-color: #98a4af; }

#btnSave_Add, #btnSave_Mod {
    background-color: #49b050;
    color: white;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight: 700;
}
#btnSave_Add:hover, #btnSave_Mod:hover { background-color: #3fa247; }
#btnSave_Add:pressed, #btnSave_Mod:pressed { background-color: #368d3d; }
</string>
